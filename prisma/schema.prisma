// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      Role     @default(ORANGTUA)
  name      String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi per role
  guru          Guru?
  orangTua      OrangTua?
  informasiList InformasiSekolah[]
  pengumumanPmbm PengumumanPmbm[]

  @@map("users")
}

enum Role {
  ADMIN
  GURU
  ORANGTUA
}

// ─────────────────────────────────────────
// PROFIL PUBLIK
// ─────────────────────────────────────────

model InformasiSekolah {
  idInfo        Int          @id @default(autoincrement())
  kategori      KategoriInfo
  judul         String       @db.VarChar(100)
  isi           String       @db.Text
  gambar        String?      @db.VarChar(255)
  tanggalUpdate DateTime     @default(now()) @updatedAt
  idUser        String

  admin User @relation(fields: [idUser], references: [id])

  @@map("informasi_sekolah")
}

enum KategoriInfo {
  sejarah
  visi
  misi
  tujuan
  fasilitas
  kurikulum
  prestasi
  berita
  ekstrakurikuler
  psb
  statistik
}

// ─────────────────────────────────────────
// DATA AKADEMIK
// ─────────────────────────────────────────

model TahunAjaran {
  id        Int       @id @default(autoincrement())
  nama      String    @unique @db.VarChar(20) // contoh: "2024/2025"
  semester  Semester
  aktif     Boolean   @default(false)
  createdAt DateTime  @default(now())

  kelas     Kelas[]

  @@map("tahun_ajaran")
}

enum Semester {
  GANJIL
  GENAP
}

model Kelas {
  id           Int    @id @default(autoincrement())
  nama         String @db.VarChar(20) // contoh: "7A", "8B"
  tingkat      Int    // 7, 8, atau 9
  tahunAjaranId Int
  waliKelasId  String?

  tahunAjaran TahunAjaran @relation(fields: [tahunAjaranId], references: [id])
  waliKelas   Guru?       @relation("WaliKelas", fields: [waliKelasId], references: [id])

  siswa       Siswa[]
  jadwal      Jadwal[]

  @@map("kelas")
}

model Guru {
  id        String  @id
  nip       String? @unique @db.VarChar(20)
  mapel     String  @db.VarChar(100)
  noHp      String? @db.VarChar(20)
  alamat    String? @db.Text
  pendidikan String? @db.VarChar(100)

  user      User   @relation(fields: [id], references: [id])

  kelasWali   Kelas[]   @relation("WaliKelas")
  jadwal      Jadwal[]
  guruMapel   GuruMapel[]
  sikapDibuat   Sikap[]   @relation("GuruSikap")
  hafalanDibuat Hafalan[] @relation("GuruHafalan")
  tahsinDibuat  Tahsin[]  @relation("GuruTahsin")
  nilaiDibuat   Nilai[]
  absensiDibuat Absensi[]

  @@map("guru")
}

model OrangTua {
  id       String  @id
  noHp     String? @db.VarChar(20)
  alamat   String? @db.Text
  pekerjaan String? @db.VarChar(100)

  user User    @relation(fields: [id], references: [id])
  anak Siswa[]

  @@map("orang_tua")
}

model Siswa {
  id           Int          @id @default(autoincrement())
  nis          String       @unique @db.VarChar(20)
  nama         String       @db.VarChar(100)
  jenisKelamin JenisKelamin
  tanggalLahir DateTime     @db.Date
  tempatLahir  String?      @db.VarChar(50)
  alamat       String?      @db.Text
  namaAyah     String?      @db.VarChar(100)
  namaIbu      String?      @db.VarChar(100)
  statusTahfidz Boolean     @default(false)
  kelasId      Int
  orangTuaId   String?
  status       Boolean      @default(true)
  createdAt    DateTime     @default(now())

  kelas    Kelas     @relation(fields: [kelasId], references: [id])
  orangTua OrangTua? @relation(fields: [orangTuaId], references: [id])

  absensi Absensi[]
  nilai   Nilai[]
  sikap   Sikap[]
  hafalan Hafalan[]
  tahsin  Tahsin[]

  @@map("siswa")
}

enum JenisKelamin {
  L
  P
}

// ─────────────────────────────────────────
// MONITORING — ABSENSI
// ─────────────────────────────────────────

model Jadwal {
  id            Int    @id @default(autoincrement())
  kelasId       Int                    // FK ke Kelas (sudah ada)
  guruId        String                 // FK ke Guru (sudah ada)
  kodeMapel     String @db.VarChar(5)  // FK ke MataPelajaran (BARU)
  tahunAjaranId Int                    // FK ke TahunAjaran (BARU)
  hari          Hari                   // enum (sudah ada)
  jamMulai      String @db.VarChar(5)  // "07:30" (sudah ada)
  jamSelesai    String @db.VarChar(5)  // "09:00" (sudah ada)

  kelas         Kelas         @relation(...)
  guru          Guru          @relation(...)
  mataPelajaran MataPelajaran @relation(...)  // BARU
  tahunAjaran   TahunAjaran   @relation(...)  // BARU
  absensi       Absensi[]

  // Constraint: 1 kelas tidak boleh punya jadwal sama
  // di hari + jam yang sama dalam 1 tahun ajaran
  @@unique([kelasId, hari, jamMulai, tahunAjaranId])
  
  // Constraint: 1 guru tidak boleh ngajar 2 kelas
  // di waktu yang sama
  @@unique([guruId, hari, jamMulai, tahunAjaranId])
  
  @@map("jadwal")
}


enum Hari {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
}

model Absensi {
  id        Int           @id @default(autoincrement())
  siswaId   Int
  jadwalId  Int
  guruId    String
  tanggal   DateTime      @db.Date
  status    StatusAbsensi
  keterangan String?      @db.VarChar(255)
  createdAt DateTime      @default(now())

  siswa  Siswa  @relation(fields: [siswaId], references: [id])
  jadwal Jadwal @relation(fields: [jadwalId], references: [id])
  guru   Guru   @relation(fields: [guruId], references: [id])

  @@unique([siswaId, jadwalId, tanggal])
  @@map("absensi")
}

enum StatusAbsensi {
  HADIR
  SAKIT
  IZIN
  ALPHA
}

// ─────────────────────────────────────────
// MONITORING — NILAI
// ─────────────────────────────────────────

model Nilai {
  id           Int        @id @default(autoincrement())
  siswaId      Int
  guruId       String
  guruMapelId  Int        // FK ke GuruMapel (TAMBAHKAN)
  jenis        JenisNilai
  nilai        Decimal    @db.Decimal(5, 2)  // 0-100
  tanggal      DateTime   @db.Date
  semester     Semester
  tahunAjar    String     @db.VarChar(20)
  keterangan   String?    @db.VarChar(255)

  siswa     Siswa     @relation(fields: [siswaId], references: [id])
  guru      Guru      @relation(fields: [guruId], references: [id])
  guruMapel GuruMapel @relation(fields: [guruMapelId], references: [idGuruMapel])

  @@map("nilai")
}

enum JenisNilai {
  HARIAN
  UTS
  UAS
  TUGAS
  PRAKTIK
}

// ─────────────────────────────────────────
// MONITORING — SIKAP
// ─────────────────────────────────────────

model Sikap {
  id         Int      @id @default(autoincrement())
  siswaId    Int
  guruId     String   // FK ke Guru (id_user role=guru)
  tanggal    DateTime @db.Date
  jenisSikap JenisSikap  // POSITIF atau PELANGGARAN
  kategori   String   @db.VarChar(50)  // "Kedisiplinan", "Atribut", dll
  keterangan String   @db.Text
  semester   Semester
  tahunAjar  String   @db.VarChar(20)
  createdAt  DateTime @default(now())

  siswa Siswa @relation(fields: [siswaId], references: [id])
  guru  Guru  @relation("GuruSikap", fields: [guruId], references: [id])

  @@map("sikap")
}
enum JenisSikap {
  POSITIF
  PELANGGARAN
}

// ─────────────────────────────────────────
// MONITORING — HAFALAN
// ─────────────────────────────────────────

model Hafalan {
  id        Int          @id @default(autoincrement())
  siswaId   Int
  guruId    String       // guru penguji
  hari      Hari
  tanggal   DateTime     @db.Date
  juz       Int          @db.TinyInt  // 1-30
  surat     String       @db.VarChar(50)  // nama surat
  halaman   Int          // 1-604
  nilai     NilaiHafalan // L atau L-
  keterangan String?     @db.Text
  createdAt  DateTime    @default(now())

  siswa Siswa @relation(fields: [siswaId], references: [id])
  guru  Guru  @relation("GuruHafalan", fields: [guruId], references: [id])

  @@map("hafalan")
}

enum NilaiHafalan {
  L      // Lancar
  L_MIN  @map("L-")  // Lancar dengan catatan
}

// ─────────────────────────────────────────
// MONITORING — TAHSIN
// ─────────────────────────────────────────

model Tahsin {
  id         Int         @id @default(autoincrement())
  siswaId    Int
  guruId     String
  hari       Hari
  tanggal    DateTime    @db.Date
  juz        Int         @db.TinyInt
  surat      String      @db.VarChar(50)
  halaman    Int
  tajwid     NilaiHafalan
  makhraj    NilaiHafalan
  sifatul    NilaiHafalan
  keterangan String?     @db.Text
  createdAt  DateTime    @default(now())

  siswa Siswa @relation(fields: [siswaId], references: [id])
  guru  Guru  @relation("GuruTahsin", fields: [guruId], references: [id])

  @@map("tahsin")
}

// ─────────────────────────────────────────
// MATA PELAJARAN
// ─────────────────────────────────────────

model MataPelajaran {
  kodeMapel String @id @db.VarChar(5)
  namaMapel String @db.VarChar(20)

  guruMapel GuruMapel[]

  @@map("mata_pelajaran")
}

// ─────────────────────────────────────────
// RELASI GURU — MATA PELAJARAN
// ─────────────────────────────────────────

model GuruMapel {
  idGuruMapel Int    @id @default(autoincrement())
  idGuru      String @db.VarChar(16)
  kodeMapel   String @db.VarChar(5)

  guru         Guru          @relation(fields: [idGuru], references: [id])
  mataPelajaran MataPelajaran @relation(fields: [kodeMapel], references: [kodeMapel])

  @@unique([idGuru, kodeMapel]) // 1 guru tidak bisa duplikat mapel yang sama
  @@map("guru_mapel")
}

model PengumumanPmbm {
  id          Int      @id @default(autoincrement())
  judul       String   @db.VarChar(200)
  deskripsi   String?  @db.Text
  filePath    String   @db.VarChar(255)
  fileName    String   @db.VarChar(255)
  tahun       String   @db.VarChar(20)
  idUser      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin User @relation(fields: [idUser], references: [id])

  @@map("pengumuman_pmbm")
}

model TahunAjaran {
  id        Int      @id @default(autoincrement())
  nama      String   @unique @db.VarChar(20) // "2025/2026"
  semester  Semester // GANJIL | GENAP
  aktif     Boolean  @default(false)
  createdAt DateTime @default(now())

  kelas   Kelas[]    // relasi ke kelas
  jadwal  Jadwal[]   // TAMBAHKAN jika belum ada

  @@map("tahun_ajaran")
}